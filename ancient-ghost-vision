  <script>
    (function () {
      var blocks = document.querySelectorAll(".lang-block");
      var tabs = document.querySelectorAll(".lang-switch a");
      function activate(lang) {
        blocks.forEach(function (b) { b.classList.toggle("active", b.id === lang); });
        tabs.forEach(function (t) { t.classList.toggle("active", t.dataset.lang === lang); });
        document.documentElement.lang = lang;
      }
      tabs.forEach(function (t) {
        t.addEventListener("click", function (e) {
          e.preventDefault();
          activate(t.dataset.lang);
          history.replaceState(null, "", "#" + t.dataset.lang);
        });
      });
      var initial = (location.hash || "").replace("#", "");
      if (initial === "en") activate("en");
      // Auto-detect English browsers but only when no hash is set.
      else if (!initial && (navigator.language || "").toLowerCase().indexOf("tr") === -1) activate("en");
    })();
  </script>
